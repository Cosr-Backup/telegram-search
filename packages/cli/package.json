    "@guiiai/logg": "catalog:",
    "@inquirer/password": "^5.1.1",
    "@moeru/eventa": "1.0.0-beta.11",
    "@node-rs/jieba": "2.0.1",
    "@tg-search/common": "workspace:*",
    "@tg-search/core": "workspace:*",
    "@tg-search/protocol": "workspace:*",
    "citty": "0.1.6",
    "env-paths": "^4.0.0",
    "telegram": "2.26.22"
  }
}
