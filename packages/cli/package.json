{
  "name": "@tg-search/cli",
  "type": "module",
  "version": "1.3.0",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "tg-search": "./dist/index.mjs"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown && node scripts/check-gramjs-bundle.mjs",
    "start": "node dist/index.mjs",
